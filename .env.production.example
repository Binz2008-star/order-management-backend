# Production Environment Variables
# Copy this to .env.production and fill in real values

# Database (REQUIRED - PostgreSQL)
DATABASE_URL="postgresql://username:password@host:port/database"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="REPLACE_WITH_REAL_32_PLUS_CHAR_SECRET"

# Next.js
NEXTAUTH_SECRET="REPLACE_WITH_REAL_32_PLUS_CHAR_SECRET"
NEXTAUTH_URL="https://your-domain.com"

# Admin seed token for production seeding
ADMIN_SEED_TOKEN="REPLACE_WITH_SECURE_ADMIN_SEED_TOKEN"

# Stripe (if using webhooks)
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# WhatsApp (if using)
WHATSAPP_WEBHOOK_SECRET="your-whatsapp-webhook-secret"

# Redis (for production rate limiting)
REDIS_URL="redis://localhost:6379"
# OR use Upstash for serverless:
# UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
