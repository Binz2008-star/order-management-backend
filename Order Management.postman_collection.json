{
	"info": {
		"_postman_id": "order-management-backend",
		"name": "Order Management Backend",
		"description": "Complete API collection for order management backend testing",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"pm.environment.set(\"token\", json.token);",
									"pm.environment.set(\"userId\", json.user.id);",
									"pm.environment.set(\"sellerId\", json.user.sellerId);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"demo@seller.com\",\n  \"password\": \"demo123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Public API",
			"item": [
				{
					"name": "Get Products",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.products && json.products.length > 0) {",
									"  pm.environment.set(\"productId1\", json.products[0].id);",
									"  pm.environment.set(\"productId2\", json.products[1] ? json.products[1].id : json.products[0].id);",
									"  pm.environment.set(\"productId3\", json.products[2] ? json.products[2].id : json.products[0].id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/public/demo-store/products",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"public",
								"demo-store",
								"products"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.order) {",
									"  pm.environment.set(\"orderId\", json.order.id);",
									"  pm.environment.set(\"orderNumber\", json.order.publicOrderNumber);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"customerPhone\": \"+11234567890\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId1}}\",\n      \"quantity\": 2\n    }\n  ],\n  \"deliveryFee\": 500,\n  \"paymentType\": \"CASH_ON_DELIVERY\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/public/demo-store/orders",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"public",
								"demo-store",
								"orders"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Seller API",
			"item": [
				{
					"name": "Get Orders",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/seller/orders",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"seller",
								"orders"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Order by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/seller/orders/{{orderId}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"seller",
								"orders",
								"{{orderId}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Order Status",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"CONFIRMED\",\n  \"reason\": \"Order confirmed via dashboard\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/seller/orders/{{orderId}}/status",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"seller",
								"orders",
								"{{orderId}}",
								"status"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Products",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/seller/products?page=1&limit=10",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"seller",
								"products"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/health",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"health"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000"
		}
	]
}
