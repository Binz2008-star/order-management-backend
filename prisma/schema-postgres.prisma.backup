// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
  STAFF
}

enum SellerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentType {
  CASH_ON_DELIVERY
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  SMS
}

enum NotificationJobStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  role      UserRole @default(STAFF)
  email     String   @unique
  phone     String?
  fullName  String   @map("full_name")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  ownedSeller      Seller?       @relation("SellerOwner")
  staffMemberships SellerStaff[]

  @@map("users")
}

model Seller {
  id             String       @id @default(cuid())
  ownerUserId    String       @unique @map("owner_user_id")
  brandName      String       @map("brand_name")
  slug           String       @unique
  whatsappNumber String?      @map("whatsapp_number")
  currency       String       @default("USD")
  status         SellerStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  owner            User              @relation("SellerOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  staff            SellerStaff[]
  products         Product[]
  customers        Customer[]
  orders           Order[]
  notificationJobs NotificationJob[]

  @@map("sellers")
}

model SellerStaff {
  id              String   @id @default(cuid())
  sellerId        String   @map("seller_id")
  userId          String   @map("user_id")
  permissionsJson Json     @map("permissions_json")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sellerId, userId])
  @@map("seller_staff")
}

model Product {
  id            String   @id @default(cuid())
  sellerId      String   @map("seller_id")
  name          String
  slug          String
  description   String?
  priceMinor    Int      @map("price_minor")
  currency      String
  stockQuantity Int      @map("stock_quantity")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  seller     Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([sellerId, slug])
  @@index([sellerId, isActive])
  @@map("products")
}

model Customer {
  id          String   @id @default(cuid())
  sellerId    String   @map("seller_id")
  name        String
  phone       String
  addressText String?  @map("address_text")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  seller Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([sellerId, phone])
  @@index([sellerId, phone])
  @@map("customers")
}

model Order {
  id                String        @id @default(cuid())
  sellerId          String        @map("seller_id")
  customerId        String        @map("customer_id")
  publicOrderNumber String        @unique @map("public_order_number")
  status            OrderStatus   @default(PENDING)
  paymentType       PaymentType   @default(CASH_ON_DELIVERY) @map("payment_type")
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  subtotalMinor     Int           @map("subtotal_minor")
  deliveryFeeMinor  Int           @default(0) @map("delivery_fee_minor")
  totalMinor        Int           @map("total_minor")
  currency          String
  source            String        @default("public_api")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  seller           Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  events           OrderEvent[]
  paymentAttempts  PaymentAttempt[]
  notificationJobs NotificationJob[]

  @@index([sellerId, createdAt])
  @@index([sellerId, status, createdAt])
  @@map("orders")
}

model OrderItem {
  id                  String @id @default(cuid())
  orderId             String @map("order_id")
  productId           String @map("product_id")
  productNameSnapshot String @map("product_name_snapshot")
  unitPriceMinor      Int    @map("unit_price_minor")
  quantity            Int
  lineTotalMinor      Int    @map("line_total_minor")

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  actorUserId String?  @map("actor_user_id")
  eventType   String   @map("event_type")
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_events")
}

model NotificationJob {
  id          String                @id @default(cuid())
  sellerId    String                @map("seller_id")
  orderId     String?               @map("order_id")
  channel     NotificationChannel
  templateKey String                @map("template_key")
  status      NotificationJobStatus @default(PENDING)
  retryCount  Int                   @default(0) @map("retry_count")
  scheduledAt DateTime              @default(now()) @map("scheduled_at")
  sentAt      DateTime?             @map("sent_at")
  errorText   String?               @map("error_text")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  // Relations
  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@map("notification_jobs")
}

model PaymentAttempt {
  id                String          @id @default(cuid())
  orderId           String          @map("order_id")
  provider          PaymentProvider
  providerReference String?         @map("provider_reference")
  amountMinor       Int             @map("amount_minor")
  currency          String
  status            PaymentStatus
  rawPayloadJson    Json?           @map("raw_payload_json")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, providerReference])
  @@index([provider, providerReference])
  @@map("payment_attempts")
}

model WebhookEvent {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventId     String          @map("event_id")
  eventType   String          @map("event_type")
  payloadJson Json            @map("payload_json")
  processedAt DateTime?       @map("processed_at")
  status      WebhookStatus   @default(PENDING)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([provider, eventId])
  @@index([provider, eventId])
  @@map("webhook_events")
}
