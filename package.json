{
  "name": "order-management-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint src prisma",
    "lint:verbose": "eslint src prisma --format stylish",
    "lint:debug": "eslint src prisma --format stylish --max-warnings=0",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit -p tsconfig.backend.json",
    "test": "vitest run --reporter=default",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:integration": "vitest --run src/tests/integration/",
    "test:unit": "vitest --run src/tests/auth.test.ts src/tests/order.test.ts",
    "test:critical": "vitest run --reporter=default src/tests/auth-hardening.test.ts src/tests/payment-confirm.test.ts src/tests/webhook-regression.test.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:legacy": "tsx prisma/seed-services.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "npm run db:reset && npm run seed",
    "postinstall": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "release:proof": "tsx scripts/release-proof-core-flow.ts",
    "release:proof:runtime": "tsx scripts/release-proof-runtime.ts",
    "env:generate": "node scripts/generate-production-env.js",
    "verify:prod": "tsx scripts/verify-production.ts",
    "quick:check": "node scripts/quick-check.js",
    "ai:worker": "tsx src/server/modules/ai/simple-worker.ts",
    "generate-sdk": "tsx scripts/generate-sdk.ts",
    "generate-openapi": "tsx scripts/generate-openapi.ts",
    "enforce:gateway-only": "node scripts/enforce-gateway-only.js",
    "test:contract": "vitest run src/tests/contract/"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.5.0",
    "@huggingface/transformers": "3.8.1",
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "5.22.0",
    "@types/bcryptjs": "2.4.6",
    "@types/better-sqlite3": "7.6.13",
    "@types/jsonwebtoken": "9.0.10",
    "@types/redis": "4.0.10",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.8.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "9.0.3",
    "nanoid": "5.1.7",
    "next": "16.2.2",
    "opossum": "^8.1.2",
    "prisma": "5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "5.11.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/opossum": "8.1.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "4.21.0",
    "typescript": "^5",
    "vitest": "4.1.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
