{{#if (and (eq auth "clerk") (ne backend "convex") (ne api "none"))}}
function ClerkApiAuthBridge() {
  const { getToken } = useAuth();

  useEffect(() => {
    setClerkAuthTokenGetter(getToken);

    return () => {
      setClerkAuthTokenGetter(null);
    };
  }, [getToken]);

  return null;
}
{{/if}}

export const links: Route.LinksFunction = () => [
