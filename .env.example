# Local development database - use Neon PostgreSQL for consistency with production
# Get your connection string from: https://console.neon.tech/
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require"

# JWT secret for authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=""

# NextAuth configuration
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Admin seed token for production seeding
ADMIN_SEED_TOKEN=""

# Stripe configuration (for webhooks)
STRIPE_WEBHOOK_SECRET=""

# WhatsApp configuration
WHATSAPP_WEBHOOK_SECRET=""

# Cron configuration (for /api/cron/reconcile-payments)
# Generate with: openssl rand -hex 32
CRON_SECRET=""
CRON_RECONCILE_LIMIT="50"

# Redis configuration for production rate limiting
# Option 1: Standard Redis
REDIS_URL="redis://localhost:6379"

# Option 2: Upstash Redis (recommended for serverless)
# UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
