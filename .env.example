DATABASE_URL="file:./dev.db"

# JWT secret for authentication
# Generate with: openssl rand -base64 32
JWT_SECRET="REPLACE_WITH_REAL_32_PLUS_CHAR_SECRET"

# NextAuth configuration
NEXTAUTH_SECRET="REPLACE_WITH_REAL_32_PLUS_CHAR_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Stripe configuration (for webhooks)
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# WhatsApp configuration
WHATSAPP_WEBHOOK_SECRET="your-whatsapp-webhook-secret"

# Redis configuration for production rate limiting
# Option 1: Standard Redis
REDIS_URL="redis://localhost:6379"

# Option 2: Upstash Redis (recommended for serverless)
# UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
